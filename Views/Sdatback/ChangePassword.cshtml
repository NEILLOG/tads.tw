@{
    Layout = "~/Views/Shared/Admin/_AdminLayout.cshtml";
    ViewData["Title"] = "變更密碼";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">變更密碼</h1>
</div>

<div class="card shadow mb-4" style="max-width: 480px;">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">修改登入密碼</h6>
    </div>
    <div class="card-body">
        <form method="post" asp-controller="Sdatback" asp-action="ChangePassword" autocomplete="off">
            <div class="form-group mb-3">
                <label class="form-label">原密碼</label>
                <input type="password" name="oldPassword" class="form-control" autocomplete="current-password" required />
            </div>
            <div class="form-group mb-3">
                <label class="form-label">新密碼</label>
                <input type="password" name="newPassword" class="form-control" autocomplete="new-password" minlength="8" required />
                <small class="text-muted">長度至少 8 碼，需同時包含英文字母與數字。</small>
            </div>
            <div class="form-group mb-3">
                <label class="form-label">確認新密碼</label>
                <input type="password" name="confirmPassword" class="form-control" autocomplete="new-password" minlength="8" required />
            </div>
            <button type="submit" class="btn btn-primary">送出變更</button>
        </form>
    </div>
</div>
