@{
    Layout = "_Layout";
    ViewData["Title"] = "Home Page";
}

@{
    var banners = ViewBag.Banners as List<TADS_Web.Models.Extend.BannerExtend> ?? new List<TADS_Web.Models.Extend.BannerExtend>();
}

@functions {
    // 依是否有連結，將圖片包成可點擊或純顯示
    string BannerImgStyle => "max-height: 700px; object-fit: cover;";
}

@if (banners.Count == 0)
{
    <!-- 無橫幅資料時的預設圖片 -->
    <img src="~/img/banner.jpg" class="w-100 d-block" alt="" style="@BannerImgStyle" />
}
else if (banners.Count == 1)
{
    var b = banners[0];
    @if (!string.IsNullOrEmpty(b.Banner.LinkUrl))
    {
        <a href="@b.Banner.LinkUrl">
            <img src="@b.ImageUrl" class="w-100 d-block" alt="@b.Banner.Title" style="@BannerImgStyle" />
        </a>
    }
    else
    {
        <img src="@b.ImageUrl" class="w-100 d-block" alt="@b.Banner.Title" style="@BannerImgStyle" />
    }
}
else
{
    <div id="homeBannerCarousel" class="carousel slide" data-bs-ride="carousel">
        <!-- 圓點指示器 -->
        <div class="carousel-indicators">
            @for (int i = 0; i < banners.Count; i++)
            {
                <button type="button" data-bs-target="#homeBannerCarousel" data-bs-slide-to="@i"
                        class="@(i == 0 ? "active" : "")" aria-current="@(i == 0 ? "true" : "false")"
                        aria-label="橫幅 @(i + 1)"></button>
            }
        </div>

        <div class="carousel-inner">
            @for (int i = 0; i < banners.Count; i++)
            {
                var b = banners[i];
                <div class="carousel-item @(i == 0 ? "active" : "")">
                    @if (!string.IsNullOrEmpty(b.Banner.LinkUrl))
                    {
                        <a href="@b.Banner.LinkUrl">
                            <img src="@b.ImageUrl" class="w-100 d-block" alt="@b.Banner.Title" style="@BannerImgStyle" />
                        </a>
                    }
                    else
                    {
                        <img src="@b.ImageUrl" class="w-100 d-block" alt="@b.Banner.Title" style="@BannerImgStyle" />
                    }
                </div>
            }
        </div>

        <!-- 左右切換箭頭 -->
        <button class="carousel-control-prev" type="button" data-bs-target="#homeBannerCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">上一張</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#homeBannerCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">下一張</span>
        </button>
    </div>
}

