                    <a href="/static/file.pdf" target="_blank" class="btn btn-primary btn-modern btn-sm font-noto-sans-tc font-weight-bold">
                        <i class="fas fa-download me-1"></i>下載檔案
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>


