<!-- 最新消息 -->
<style>
    .news-home ul {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .news-home li {
        border-bottom: 1px dotted #d6d6d6;
        padding: 1rem 0;
    }

    .news-home li:last-child {
        border-bottom: none;
    }

    .news-home .news-date {
        white-space: nowrap;
        color: #999;
    }

    .news-home .news-category {
        display: inline-block;
        background-color: #C89B3C;
        color: #fff;
        border-radius: 3px;
        padding: 0.1rem 0.6rem;
        white-space: nowrap;
    }

    .news-home .news-title a {
        color: #212529;
        text-decoration: none;
        transition: color 0.2s ease;
    }

    .news-home .news-title a:hover {
        color: #C89B3C;
    }
</style>

<section class="section section-no-border my-0 py-5" style="background-color: #fff;">
    <div class="container py-3">
        <div class="row mb-4">
            <div class="col">
                <h2 class="mb-0 font-weight-bold text-dark font-merriweather">Latest News <div style="display: inline-block;" class="ms-4 font-noto-serif-tc font-weight-bold">最新消息</div></h2>
                <div class="divider divider-primary divider-small mt-2 mb-4">
                    <hr class="my-0 me-auto">
                </div>
            </div>
        </div>

        @{
            var newsLatest = ViewBag.NewsLatest as List<TADS_Web.Models.Extend.NewsExtend>;
        }
        <div class="row news-home">
            <div class="col-12">
                @if (newsLatest != null && newsLatest.Count > 0)
                {
                    <ul>
                        @foreach (var item in newsLatest)
                        {
                            <li class="d-flex align-items-start flex-wrap gap-2">
                                <span class="news-date text-2 text-uppercase">@item.News.DisplayDate.ToString("yyyy/MM/dd")</span>
                                @if (!string.IsNullOrEmpty(item.News.Category))
                                {
                                    <span class="news-category text-1">@item.News.Category</span>
                                }
                                <h4 class="news-title text-4 line-height-3 font-weight-bold mb-0 flex-fill">
                                    <a href="@Url.Action("News", "Home", new { id = item.News.Id })">@item.News.Title</a>
                                </h4>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="text-center text-muted py-4">目前暫無資料</div>
                }
            </div>
        </div>

        @if (newsLatest != null && newsLatest.Count > 0)
        {
            <div class="row mt-4">
                <div class="col text-center">
                    <a href="@Url.Action("NewsList", "Home")" class="btn btn-primary btn-modern text-2 font-weight-semibold text-uppercase">View All</a>
                </div>
            </div>
        }
    </div>
</section>


<!-- 關於學會 -->
<div class="container-fluid">
    <div class="row" style="background: url(img/background-1.jpg); background-size: contain; background-position: center;">
        <div class="col-lg-6 order-2 order-lg-1 p-0">
            <div class="h-100 m-0">
                <div class="row m-0">
                    <div class="col-half-section col-half-section-right text-color-light py-5 ms-auto">
                        <div class="p-3">
                            <div class="appear-animation" data-appear-animation="fadeInRightShorter" data-appear-animation-delay="200">
                                <h2 class="mb-0 font-weight-bold text-light font-noto-serif-tc">關於學會</h2>
                                <div class="divider divider-dark divider-small mt-2 mb-4">
                                    <hr class="my-0 me-auto">
                                </div>

                                <div class="testimonial testimonial-style-2 testimonial-with-quotes testimonial-quotes-light testimonial-remove-right-quote mb-0">
                                    <blockquote class="opacity-7 pb-3">
                                        <p class="text-start text-color-light custom-font-secondary font-weight-bold text-45 line-height-10 pb-0 mb-0 font-noto-sans-tc">
                                            發展研究（development studies），起初以國家為主的經濟發展考量，近年來逐漸轉移到個人、社區、參與以及平等，強調發展是要符合人民需要、與環境和平共處。為實現發展的永續性，除借鑑前人的經驗更需結合現今資源網絡，我們期許能夠找到一條可以實現永續的發展道路。</p>
                                    </blockquote>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6 order-1 order-lg-2 p-0">
            <section class="parallax section section-parallax custom-parallax-bg-pos-left custom-sec-left h-100 m-0" data-plugin-parallax data-plugin-options="{'speed': 1.5, 'horizontalPosition': '100%'}" style="min-height: 450px;">
                <div class="h-100 m-0">
                    <div class="row m-0">
                        <div class="col-half-section col-half-section-left">
                            <div class="p-3 p-relative zindex-1">
                                <div class="appear-animation" data-appear-animation="fadeInLeftShorter" data-appear-animation-delay="400">
                                    <h2 class="mb-0 font-weight-bold text-color-light font-merriweather">About Us</h2>
                                    <div class="divider divider-dark divider-small mt-2 mb-4">
                                        <hr class="my-0 me-auto">
                                    </div>

                                    <div>
                                        <p class="text-color-light font-noto-sans text-4" style="line-height: 1.3em;">Development studies, initially focusing on national economic growth, have gradually shifted to sustainability of individuals, communities, civic participation, equality, and global governance in recent years, emphasizing that development must meet the needs of the people and coexist with nature. To realize the sustainability, it is crucial to acquire experience from the predecessors, as well as to integrate the current resource network into practice. Therefore, as an association for development studies, we hope to find a sustainable path by connecting scholars from various research fields.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </section>
        </div>

    </div>
</div>


<!-- 以文會友 Member Research 最新六筆 -->
<style>
    .member-research-home article {
        padding-bottom: 1.5rem;
        border-bottom: 1px dotted #d6d6d6;
    }

    .member-research-home .col-md-6:nth-last-child(-n+2) article {
        border-bottom: none;
        padding-bottom: 0;
    }

    .member-research-home-thumb {
        display: block;
        width: 96px;
        height: 96px;
        overflow: hidden;
        flex-shrink: 0;
    }

    .member-research-home-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        background-color: #fff;
        transition: transform 0.3s ease;
    }

    .member-research-home-thumb:hover img {
        transform: scale(1.05);
    }

    .member-research-home-body .post-title a {
        color: #212529;
        text-decoration: none;
        transition: color 0.2s ease;
    }

    .member-research-home-body .post-title a:hover {
        color: #C89B3C;
    }

    .member-research-home-body .post-meta {
        color: #999;
    }
</style>

<section class="section section-default section-no-border my-0 py-5">
    <div class="container py-3">
        <div class="row mb-4">
            <div class="col">
                <h2 class="mb-0 font-weight-bold text-dark font-merriweather">Member Research <div style="display: inline-block;" class="ms-4 font-noto-serif-tc font-weight-bold">以文會友</div></h2>
                <div class="divider divider-primary divider-small mt-2 mb-4">
                    <hr class="my-0 me-auto">
                </div>
                <p class="text-3 text-muted font-noto-sans-tc mb-0">分享學會會員在發展研究及相關領域的最新著作與研究成果</p>
            </div>
        </div>

        @{
            var researchLatest = ViewBag.MemberResearchLatest as List<TADS_Web.Models.Extend.MemberResearchExtend>;
        }
        <div class="row member-research-home">
            @if (researchLatest != null && researchLatest.Count > 0)
            {
                foreach (var item in researchLatest)
                {
                    string detailUrl = Url.Action("Detail", "MemberResearch", new { id = item.Research.Id });
                    string cover = string.IsNullOrEmpty(item.CoverUrl) ? Url.Content("~/img/blank.gif") : item.CoverUrl;
                    <div class="col-md-6 mb-4">
                        <article class="d-flex align-items-start">
                            <a href="@detailUrl" class="member-research-home-thumb me-3">
                                <img src="@cover" alt="@item.Research.Title" />
                            </a>
                            <div class="member-research-home-body">
                                <h4 class="post-title text-4 line-height-3 font-weight-bold mb-1">
                                    <a href="@detailUrl">@item.Research.Title</a>
                                </h4>
                                @if (!string.IsNullOrEmpty(item.Research.AuthorInfo))
                                {
                                    <p class="post-meta text-2 mb-1">@item.Research.AuthorInfo</p>
                                }
                                <span class="post-meta text-1 text-uppercase">@item.Research.CreateDate.ToString("MMMM d, yyyy")</span>
                            </div>
                        </article>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center text-muted py-4">目前暫無資料</div>
            }
        </div>

        @if (researchLatest != null && researchLatest.Count > 0)
        {
            <div class="row">
                <div class="col text-center">
                    <a href="@Url.Action("List", "MemberResearch")" class="btn btn-primary btn-modern text-2 font-weight-semibold text-uppercase">View All</a>
                </div>
            </div>
        }
    </div>
</section>


