@using System.Globalization
@using System.Text.RegularExpressions
@model List<TADS_Web.Models.Extend.NewsExtend>
@{
    Layout = "_LayoutInner";
    ViewData["Title"] = "最新消息";
    ViewData["PageTitle"] = "Latest News 最新消息";
    ViewData["BreadcrumbCurrent"] = "最新消息";

    var recentNews = ViewBag.RecentNews as List<TADS_Web.Models.Extend.NewsExtend> ?? new List<TADS_Web.Models.Extend.NewsExtend>();
    var categoryCounts = ViewBag.CategoryCounts as List<KeyValuePair<string, int>> ?? new List<KeyValuePair<string, int>>();
    string currentCategory = ViewBag.CurrentCategory as string;

    Func<string, string> excerpt = html =>
    {
        if (string.IsNullOrEmpty(html)) return string.Empty;
        string text = Regex.Replace(html, "<.*?>", " ");
        text = System.Net.WebUtility.HtmlDecode(text);
        text = Regex.Replace(text, "\\s+", " ").Trim();
        return text.Length > 120 ? text.Substring(0, 120) + "…" : text;
    };
}

<div class="container py-5 my-3">
	<div class="row">
		<div class="col-lg-8 mb-5 mb-lg-0">

			@if (!string.IsNullOrEmpty(currentCategory))
			{
				<p class="text-3 text-color-default mb-4">
					分類：<span class="font-weight-bold text-color-dark">@currentCategory</span>
					<a href="@Url.Action("NewsList", "Home")" class="text-color-primary text-decoration-none ms-2">（檢視全部）</a>
				</p>
			}

			@if (Model != null && Model.Count > 0)
			{
				foreach (var item in Model)
				{
					string detailUrl = Url.Action("News", "Home", new { id = item.News.Id });
					<article class="pb-4 mb-4" style="border-bottom: 1px solid #eee;">
						<p class="text-uppercase text-1 mb-2 text-color-default">
							<time pubdate datetime="@item.News.DisplayDate.ToString("yyyy-MM-dd")">@item.News.DisplayDate.ToString("d MMM yyyy", CultureInfo.InvariantCulture)</time>
							@if (!string.IsNullOrEmpty(item.News.Category))
							{
								<span class="opacity-3 d-inline-block px-2">|</span> @item.News.Category
							}
						</p>
						<h3 class="font-weight-bold text-5 mb-2">
							<a href="@detailUrl" class="text-color-dark text-hover-primary text-decoration-none">@item.News.Title</a>
						</h3>
						<p class="text-3 text-color-default mb-2">@excerpt(item.News.Contents)</p>
						<a href="@detailUrl" class="text-color-primary font-weight-semibold text-2 text-decoration-none">閱讀更多 &raquo;</a>
					</article>
				}
			}
			else
			{
				<div class="text-center text-muted py-5">目前暫無最新消息</div>
			}

		</div>
		<div class="blog-sidebar col-lg-4 pt-4 pt-lg-0">
			<aside class="sidebar">

				<div class="px-3 mt-4">
					<h3 class="text-color-dark text-capitalize font-weight-bold text-5 m-0 mb-3">Recent Posts</h3>
					<div class="pb-2 mb-1">
						@if (recentNews.Count > 0)
						{
							foreach (var item in recentNews)
							{
								<a href="@Url.Action("News", "Home", new { id = item.News.Id })" class="text-color-default text-uppercase text-1 mb-0 d-block text-decoration-none">
									@item.News.DisplayDate.ToString("d MMM yyyy", CultureInfo.InvariantCulture)
									@if (!string.IsNullOrEmpty(item.News.Category))
									{
										<span class="opacity-3 d-inline-block px-2">|</span> @item.News.Category
									}
								</a>
								<a href="@Url.Action("News", "Home", new { id = item.News.Id })" class="text-color-dark text-hover-primary font-weight-bold text-3 d-block pb-3 line-height-4">@item.News.Title</a>
							}
						}
						else
						{
							<p class="text-2 text-muted mb-0">目前暫無資料</p>
						}
					</div>
				</div>
				<div class="py-1 clearfix">
					<hr class="my-2">
				</div>
				<div class="px-3 mt-4">
					<h3 class="text-color-dark text-capitalize font-weight-bold text-5 m-0">Categories</h3>
					<ul class="nav nav-list flex-column mt-2 mb-0 p-relative right-9">
						<li class="nav-item">
							<a class="nav-link bg-transparent border-0 @(string.IsNullOrEmpty(currentCategory) ? "active" : "")" href="@Url.Action("NewsList", "Home")">全部</a>
						</li>
						@foreach (var cat in categoryCounts)
						{
							<li class="nav-item">
								<a class="nav-link bg-transparent border-0 @(cat.Key == currentCategory ? "active" : "")" href="@Url.Action("NewsList", "Home", new { category = cat.Key })">@cat.Key (@cat.Value)</a>
							</li>
						}
					</ul>
				</div>
			</aside>
		</div>
	</div>
</div>
