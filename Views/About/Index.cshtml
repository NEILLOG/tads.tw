@using TADS_Web.Extensions
@model TADS_Web.Models.VM_AboutContent
@{
    Layout = "_LayoutInner";
    ViewData["Title"] = "About 關於我們";
    ViewData["PageTitle"] = "About 關於我們";
    ViewData["BreadcrumbCurrent"] = "About 關於我們";

    var a = Model.AboutItem;
    var introParas = (a.IntroDetail ?? "").Split(new[] { "\r\n\r\n", "\n\n", "\r\r" }, StringSplitOptions.RemoveEmptyEntries);
    int term = a.BoardTermNo ?? 0;
    string boardTitle = term > 0
        ? $"第{NumberFormat.ToChineseNumeral(term)}屆理監事名單 List of the {NumberFormat.ToOrdinal(term)} Board Members"
        : "理監事名單 List of Board Members";
    var priceBySlot = Model.PricingList.ToDictionary(x => x.SortOrder);
}

<section class="section section-default section-no-border my-0">
    <div class="container pt-3 pb-4">

        <!-- Introduce 標題 -->
        <div class="row">
            <div class="col-12">
                <div class="">
                    <h1 class="font-merriweather font-italic mb-0" style="font-weight: 700;">Introduce</h1>
                    <div class="divider divider-primary divider-small mt-2 mb-4">
                        <hr class="my-0 me-auto">
                    </div>
                </div>
            </div>
        </div>

        <!-- 學會名稱 -->
        <div class="row">
            <div class="col-12">
                <div class="">
                    <h4 class="font-noto-serif-tc font-weight-bold text-primary mb-1">@a.IntroNameZh</h4>
                    <h4 class="font-noto-serif-tc font-weight-bold text-primary mb-0">@a.IntroNameEn</h4>
                </div>
            </div>
        </div>

        <!-- 左：簡介 + 圖片　右：詳細內文 -->
        <div class="row mt-4">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <div class="">
                    <p class="font-noto-sans-tc font-weight-bold text-dark text-3-5" style="line-height: 1.7em;">
                        @a.IntroSummary
                    </p>
                    <img src="@Model.IntroImageUrl" class="w-100 d-block mt-4" alt="台灣發展研究學會" />
                </div>
            </div>
            <div class="col-lg-6">
                <div class="font-noto-sans-tc text-dark" style="line-height: 1.9em;">
                    @for (int i = 0; i < introParas.Length; i++)
                    {
                        <p class="@(i == introParas.Length - 1 ? "mb-0" : "")">@introParas[i].Trim()</p>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Organizational Chart 組織圖 -->
<style>
    .org-chart-lightbox {
        cursor: zoom-in;
        transition: opacity .2s ease;
    }
    /* 透明背景組織圖在燈箱中加白底 */
    .mfp-org-chart .mfp-img {
        background-color: #fff;
        padding: 30px;
        box-sizing: border-box;
        border-radius: 4px;
    }
    .org-chart-lightbox:hover {
        opacity: 0.85;
    }
    .org-accordion {
        margin-bottom: 22px;
    }
    .org-acc-input {
        display: none;
    }
    .org-acc-label {
        display: flex;
        align-items: center;
        cursor: pointer;
        margin-bottom: 0;
    }
    .org-acc-icon {
        flex: 0 0 auto;
        width: 30px;
        height: 30px;
        margin-right: 14px;
        background-color: var(--primary, #b89968);
        border-radius: 3px;
        position: relative;
    }
    .org-acc-icon::before,
    .org-acc-icon::after {
        content: "";
        position: absolute;
        top: 50%;
        left: 50%;
        background-color: #fff;
        transform: translate(-50%, -50%);
    }
    .org-acc-icon::before {
        width: 14px;
        height: 2px;
    }
    .org-acc-icon::after {
        width: 2px;
        height: 14px;
        transition: transform .2s ease;
    }
    /* 展開時 + 變 - */
    .org-acc-input:checked + .org-acc-label .org-acc-icon::after {
        transform: translate(-50%, -50%) scaleY(0);
    }
    .org-acc-title {
        font-weight: 700;
        color: #212529;
        font-size: 1.15rem;
    }
    .org-acc-content {
        overflow: hidden;
        max-height: 0;
        opacity: 0;
        transition: max-height .3s ease, opacity .3s ease;
        padding-left: 44px;
    }
    .org-acc-input:checked ~ .org-acc-content {
        max-height: 3000px;
        opacity: 1;
        margin-top: 18px;
    }
    .org-role {
        margin-bottom: 18px;
    }
    .org-role-title {
        font-weight: 700;
        color: #212529;
        margin-bottom: 2px;
    }
    .org-role-note {
        font-weight: 400;
        font-size: 0.95rem;
    }
    .org-role-name {
        color: #6c757d;
        margin-bottom: 0;
        line-height: 1.7em;
    }
</style>
<section class="section section-default section-no-border my-0" style="padding-top: 0;">
    <div class="container pt-0 pb-4">

        <!-- 區塊標題 -->
        <div class="row">
            <div class="col-12">
                <div class="">
                    <h1 class="font-merriweather font-italic mb-0" style="font-weight: 700;">Organizational Chart</h1>
                    <div class="divider divider-primary divider-small mt-2 mb-4">
                        <hr class="my-0 me-auto">
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-4">
            <!-- 左：組織結構圖 -->
            <div class="col-lg-6 mb-5 mb-lg-0">
                <div class="">
                    <a href="@Model.OrgChartUrl" class="d-block org-chart-lightbox"
                       data-plugin-lightbox data-plugin-options='{"type":"image","mainClass":"mfp-org-chart"}'
                       title="台灣發展研究學會組織圖">
                        <img src="@Model.OrgChartUrl" class="w-100 d-block" alt="台灣發展研究學會組織圖" />
                    </a>
                </div>
            </div>

            <!-- 右：理監事名單 -->
            <div class="col-lg-6">
                <div class="font-noto-serif-tc">

                    <!-- 本屆理監事名單 -->
                    <div class="org-accordion">
                        <input type="checkbox" id="org-board-7" class="org-acc-input" checked>
                        <label for="org-board-7" class="org-acc-label">
                            <span class="org-acc-icon"></span>
                            <span class="org-acc-title">@boardTitle</span>
                        </label>
                        <div class="org-acc-content">
                            @if (!string.IsNullOrWhiteSpace(a.BoardPresident))
                            {
                                <div class="org-role">
                                    <p class="org-role-title">理事長 President：</p>
                                    <p class="org-role-name">@a.BoardPresident</p>
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(a.BoardVicePresident))
                            {
                                <div class="org-role">
                                    <p class="org-role-title">副理事長 Vice President：</p>
                                    <p class="org-role-name">@a.BoardVicePresident</p>
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(a.BoardExecDirectors))
                            {
                                <div class="org-role">
                                    <p class="org-role-title">常務理事 Executive Directors<br><span class="org-role-note">(依筆劃順序排序 / Listed by stroke count)：</span></p>
                                    <p class="org-role-name">@a.BoardExecDirectors</p>
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(a.BoardDirectors))
                            {
                                <div class="org-role">
                                    <p class="org-role-title">理事 Directors<br><span class="org-role-note">(依筆劃順序排序 / Listed by stroke count)：</span></p>
                                    <p class="org-role-name">@a.BoardDirectors</p>
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(a.BoardExecSupervisor))
                            {
                                <div class="org-role">
                                    <p class="org-role-title">常務監事 Executive Supervisor：</p>
                                    <p class="org-role-name">@a.BoardExecSupervisor</p>
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(a.BoardSupervisors))
                            {
                                <div class="org-role">
                                    <p class="org-role-title">監事 Supervisors<br><span class="org-role-note">(依筆劃順序排序 / Listed by stroke count)：</span></p>
                                    <p class="org-role-name">@a.BoardSupervisors</p>
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(a.BoardSecretaryGeneral))
                            {
                                <div class="org-role">
                                    <p class="org-role-title">秘書長 Secretary-General：</p>
                                    <p class="org-role-name">@a.BoardSecretaryGeneral</p>
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(a.BoardExecSecretary))
                            {
                                <div class="org-role">
                                    <p class="org-role-title">執行秘書 Executive Secretary：</p>
                                    <p class="org-role-name">@a.BoardExecSecretary</p>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- 歷屆理監事名單 -->
                    <div class="org-accordion">
                        <input type="checkbox" id="org-board-past" class="org-acc-input">
                        <label for="org-board-past" class="org-acc-label">
                            <span class="org-acc-icon"></span>
                            <span class="org-acc-title">歷屆理監事名單 List of Past Board</span>
                        </label>
                        <div class="org-acc-content">
                            <div class="d-flex align-items-center flex-wrap gap-3 mt-2">
                                <span class="org-role-name mb-0">下載歷屆理監事名單</span>
                                <a href="@(string.IsNullOrWhiteSpace(a.PastBoardListUrl) ? "#" : a.PastBoardListUrl)"
                                   target="_blank" rel="noopener noreferrer"
                                   class="btn btn-primary btn-modern font-noto-serif-tc font-weight-bold">
                                    Download 下載
                                </a>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>

<!-- Membership Application 入會申請 -->
<section class="section section-default section-no-border my-0" style="padding-top: 0;">
    <div class="container pt-0 pb-4">

        <!-- 區塊標題 -->
        <div class="row">
            <div class="col-12">
                <div class="">
                    <h1 class="font-merriweather font-italic mb-0" style="font-weight: 700;">Membership Application</h1>
                    <div class="divider divider-primary divider-small mt-2 mb-4">
                        <hr class="my-0 me-auto">
                    </div>
                </div>
            </div>
        </div>

        <!-- 入會申請小標 -->
        <div class="row">
            <div class="col-12">
                <div class="">
                    <h4 class="font-noto-serif-tc font-weight-bold text-primary mb-1">入會申請</h4>
                    <h4 class="font-noto-serif-tc font-weight-bold text-primary mb-0">Join the membership of TADS</h4>
                </div>
            </div>
        </div>

        <!-- 左：中文邀請　右：英文邀請 -->
        <div class="row mt-4">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <div class="">
                    <p class="font-noto-sans-tc font-weight-bold text-dark text-3-5 mb-0" style="line-height: 1.9em;">
                        @a.MembershipInviteZh
                    </p>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="">
                    <p class="font-noto-sans text-dark mb-0" style="line-height: 1.9em;">
                        @a.MembershipInviteEn
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Membership Fees 會費價格表 -->
<style>
    .fee-pricing .fee-col {
        margin-bottom: 24px;
    }
    .fee-plan {
        display: flex;
        flex-direction: column;
        height: 100%;
        background-color: #fff;
        text-align: center;
    }
    .fee-cat {
        padding: 12px 10px;
        color: #fff;
        min-height: 92px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }
    .fee-cat .fee-cat-tc {
        font-size: 0.95rem;
        font-weight: 700;
        line-height: 1.4em;
    }
    .fee-cat .fee-cat-en {
        font-size: 0.8rem;
        line-height: 1.3em;
        opacity: 0.95;
    }
    .fee-type {
        padding: 12px 10px;
        color: #fff;
        min-height: 108px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }
    .fee-type .fee-type-tc {
        font-size: 1.45rem;
        font-weight: 700;
        line-height: 1.3em;
    }
    .fee-type .fee-type-en {
        font-size: 0.9rem;
        font-weight: 600;
        line-height: 1.3em;
    }
    .fee-price {
        background-color: #e3e3e3;
        padding: 20px 10px;
        min-height: 160px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
    .fee-price--tall {
        min-height: 268px;
    }
    .fee-price .fee-amount {
        font-size: 1.9rem;
        font-weight: 800;
        color: #1a1a1a;
        line-height: 1em;
        letter-spacing: -0.5px;
    }
    .fee-price .fee-amount .fee-unit {
        font-size: 1.1rem;
        font-weight: 700;
        vertical-align: baseline;
        margin-right: 1px;
    }
    .fee-price .fee-period {
        margin-top: 12px;
        margin-bottom: 0;
        font-size: 0.78rem;
        letter-spacing: 0.04em;
        color: #8a8a8a;
        line-height: 1.5em;
    }
    .fee-desc {
        padding: 22px 20px 26px;
        text-align: left;
        flex: 1 1 auto;
    }
    .fee-desc p {
        font-size: 0.9rem;
        line-height: 1.7em;
        color: #555;
        margin-bottom: 1em;
    }
    .fee-desc p:last-child {
        margin-bottom: 0;
    }
    .fee-desc .fee-desc-tc {
        color: #333;
        font-weight: 700;
    }
    @@media (min-width: 1200px) {
        .fee-pricing .fee-col {
            flex: 0 0 auto;
            width: 16.666667%;
        }
    }
</style>

@{
    // 各卡片固定的分類色帶 / 會員別色帶 / 期間文字（顏色、單位固定；名稱/金額/說明由 DB 提供）
    var feeSlots = new[]
    {
        new { N = 1, CatTc = "",       CatEn = "",                        CatColor = "#1a1a1a", HasType = false, TypeColor = "",        Period = "PER PERSON<br>OR<br>ORGANIZATION", Tall = true  },
        new { N = 2, CatTc = "年度會費", CatEn = "Annual Membership Fees",   CatColor = "#1a1a1a", HasType = true,  TypeColor = "#b8986a", Period = "PER PERSON / YEAR",                 Tall = false },
        new { N = 3, CatTc = "年度會費", CatEn = "Annual Membership Fees",   CatColor = "#1a1a1a", HasType = true,  TypeColor = "#f0ab2e", Period = "PER PERSON / YEAR",                 Tall = false },
        new { N = 4, CatTc = "年度會費", CatEn = "Annual Membership Fees",   CatColor = "#1a1a1a", HasType = true,  TypeColor = "#6cc0e8", Period = "PER ORGANIZATION / YEAR",           Tall = false },
        new { N = 5, CatTc = "年度會費", CatEn = "Annual Membership Fees",   CatColor = "#1a1a1a", HasType = true,  TypeColor = "#3aa583", Period = "PER ORGANIZATION / YEAR",           Tall = false },
        new { N = 6, CatTc = "終身會費", CatEn = "Lifetime Membership Fee",  CatColor = "#cbb23f", HasType = true,  TypeColor = "#8a8a8a", Period = "PER PERSON",                       Tall = false },
    };
}

<section class="section section-default section-no-border my-0" style="padding-top: 0;">
    <div class="container pt-0 pb-4">

        <div class="fee-pricing row font-noto-sans-tc">

            @foreach (var s in feeSlots)
            {
                var p = priceBySlot.ContainsKey(s.N) ? priceBySlot[s.N] : null;
                <div class="fee-col col-6 col-md-4">
                    <div class="fee-plan">
                        <div class="fee-cat" style="background-color: @s.CatColor;">
                            <div class="fee-cat-tc">@(s.HasType ? s.CatTc : p?.NameZh)</div>
                            <div class="fee-cat-en font-noto-sans">@(s.HasType ? s.CatEn : p?.NameEn)</div>
                        </div>
                        @if (s.HasType)
                        {
                            <div class="fee-type" style="background-color: @s.TypeColor;">
                                <div class="fee-type-tc">@p?.NameZh</div>
                                <div class="fee-type-en font-noto-sans">@p?.NameEn</div>
                            </div>
                        }
                        <div class="fee-price @(s.Tall ? "fee-price--tall" : "")">
                            <div class="fee-amount"><span class="fee-unit">NTD$</span>@p?.Price</div>
                            <p class="fee-period font-noto-sans">@Html.Raw(s.Period)</p>
                        </div>
                        <div class="fee-desc">
                            <p>@p?.DescZh</p>
                            <p class="font-noto-sans">@p?.DescEn</p>
                        </div>
                    </div>
                </div>
            }

        </div>
    </div>
</section>

<!-- Constitution of TADS 章程 -->
<style>
    #constitution-acc:checked ~ .org-acc-content {
        max-height: 30000px;
    }
    .constitution-text {
        white-space: pre-wrap;
        font-size: 0.95rem;
        line-height: 1.95em;
        color: #444;
        border: 1px solid #d8d8d8;
        background-color: #fff;
        border-radius: 4px;
        padding: 24px 26px;
        margin-top: 4px;
    }
</style>

<section class="section section-default section-no-border my-0" style="padding-top: 0;">
    <div class="container pt-0 pb-4">

        <!-- 區塊標題 -->
        <div class="row">
            <div class="col-12">
                <div>
                    <h1 class="font-merriweather font-italic mb-0" style="font-weight: 700;">Constitution of TADS</h1>
                    <div class="divider divider-primary divider-small mt-2 mb-4">
                        <hr class="my-0 me-auto">
                    </div>
                </div>
            </div>
        </div>

        <!-- 副標題 + 下載 -->
        <div class="row align-items-start">
            <div class="col-lg-8">
                <h4 class="font-noto-serif-tc font-weight-bold text-primary mb-1">台灣發展研究學會章程</h4>
                <h4 class="font-noto-serif-tc font-weight-bold text-primary mb-0">The Constitution of the Taiwanese Association for Development Studies</h4>
            </div>
            <div class="col-lg-4 mt-3 mt-lg-0 d-flex align-items-center justify-content-lg-end">
                <span class="font-noto-sans-tc font-weight-bold text-dark me-3">下載章程</span>
                <a href="@Model.ConstitutionPdfUrl" target="_blank" rel="noopener noreferrer"
                   class="btn btn-primary btn-modern font-noto-serif-tc font-weight-bold">
                    Download 下載
                </a>
            </div>
        </div>

        <!-- 章程內容（手風琴） -->
        <div class="row mt-4">
            <div class="col-12">
                <div class="org-accordion font-noto-sans-tc">
                    <input type="checkbox" id="constitution-acc" class="org-acc-input">
                    <label for="constitution-acc" class="org-acc-label">
                        <span class="org-acc-icon"></span>
                        <span class="org-acc-title">章程 Constitution of TADS</span>
                    </label>
                    <div class="org-acc-content">
<div class="constitution-text">@a.ConstitutionText</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 以文會友 Member Research -->
