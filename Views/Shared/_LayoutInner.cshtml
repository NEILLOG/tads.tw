<!DOCTYPE html>
<html lang="en">
<head>
    @await Html.PartialAsync("_Head")
</head>

<body>
    <div class="body">
        @await Html.PartialAsync("_Header")

        <div role="main" class="main">

            <!-- 內頁頁首：麵包屑區塊 -->
            <section class="page-header page-header-modern bg-color-quaternary page-header-lg border-0 m-0">
                <div class="container position-relative z-index-2">
                    <div class="row text-center text-md-start py-3">
                        <div class="col-md-8 order-2 order-md-1 align-self-center p-static">
                            <h1 class="font-weight-bold text-color-dark text-10 mb-0 font-mixed-serif">
                                @(ViewData["PageTitle"] ?? ViewData["Title"])
                            </h1>
                        </div>
                        <div class="col-md-4 order-1 order-md-2 align-self-center">
                            <ul class="breadcrumb breadcrumb-dark font-weight-bold d-block text-md-end text-4 mb-0">
                                <li><a href="/" class="text-decoration-none text-dark">首頁</a></li>
                                @if (ViewData["BreadcrumbParent"] != null)
                                {
                                    <li><a href="@ViewData["BreadcrumbParentUrl"]" class="text-decoration-none text-dark">@ViewData["BreadcrumbParent"]</a></li>
                                }
                                <li class="text-uppercase active text-color-primary">
                                    @(ViewData["BreadcrumbCurrent"] ?? ViewData["PageTitle"] ?? ViewData["Title"])
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </section>

            @RenderBody()
        </div>

        @await Html.PartialAsync("_Footer")
    </div>

    @await Html.PartialAsync("_Scripts")
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
